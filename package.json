{
  "name": "@021.is/spine-ts",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "description": "Spine-TS monorepo \u2014 shared TypeScript packages for every 021 product",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run build:foundation && bun run build:rest",
    "build:foundation": "bun run --filter @021.is/spine-errors --filter @021.is/spine-env --filter @021.is/spine-testing build",
    "build:rest": "bun run --filter @021.is/spine-http --filter @021.is/spine-auth --filter @021.is/spine-telemetry --filter @021.is/spine-actions --filter @021.is/spine-ratelimit --filter @021.is/spine-webhooks --filter @021.is/spine-email --filter @021.is/spine-cache --filter @021.is/spine-jobs --filter @021.is/spine-i18n --filter @021.is/spine-query --filter @021.is/spine-quality --filter @021.is/spine-lint --filter @021.is/agent-docs --filter @021.is/spine build",
    "test": "vitest run --reporter=verbose --reporter=github-actions",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "@vitest/coverage-v8": "^2.1.2"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.2"
  }
}
