{
  "name": "@021/spine-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Spine-TS monorepo — shared TypeScript packages for every 021 product",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "vitest run --reporter=verbose --reporter=github-actions",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "@vitest/coverage-v8": "^2.1.2"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.2"
  }
}
