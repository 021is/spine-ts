{
  "name": "@021/spine-i18n",
  "version": "0.1.0",
  "description": "i18n runtime for every 021 product. Hexagonal: domain + ports + R2/fs/memory adapters. CLDR plurals. React + server runtimes. Generalized from DanceClub's locale lib.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./react": { "types": "./dist/react.d.ts", "import": "./dist/react.js" },
    "./server": { "types": "./dist/server.d.ts", "import": "./dist/server.js" },
    "./r2": { "types": "./dist/adapters/r2.d.ts", "import": "./dist/adapters/r2.js" },
    "./fs": { "types": "./dist/adapters/fs.d.ts", "import": "./dist/adapters/fs.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/react.tsx src/server.ts src/adapters/r2.ts src/adapters/fs.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@021/spine-errors": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "@aws-sdk/client-s3": ">=3"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "@aws-sdk/client-s3": { "optional": true }
  }
}
