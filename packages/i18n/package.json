{
  "name": "@021is/spine-i18n",
  "version": "0.2.0",
  "description": "i18n runtime for every 021 product. Hexagonal: domain + ports + R2/fs/memory adapters. CLDR plurals. React + server runtimes. Generalized from DanceClub's locale lib.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./r2": {
      "types": "./dist/adapters/driven/r2.d.ts",
      "import": "./dist/adapters/driven/r2.js"
    },
    "./fs": {
      "types": "./dist/adapters/driven/fs.d.ts",
      "import": "./dist/adapters/driven/fs.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/react.tsx src/server.ts src/adapters/driven/r2.ts src/adapters/driven/fs.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@021is/spine-errors": "^0.2.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "@aws-sdk/client-s3": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.668.0",
    "@types/react": "^19.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/021is/spine-ts.git",
    "directory": "packages/i18n"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
