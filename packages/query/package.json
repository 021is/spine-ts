{
  "name": "@021is/spine-query",
  "version": "0.3.0",
  "description": "TanStack Query wrapper with 021 defaults: dedupe, SWR, no auto-refetch, query-key factory pattern. Reduces frontend \u2192 backend traffic.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.100.14",
    "react": "^19.2.6"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": false
    },
    "react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/021is/spine-ts.git",
    "directory": "packages/query"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
