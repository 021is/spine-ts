{
  "name": "@021.is/spine-ratelimit",
  "version": "0.4.3",
  "license": "MIT",
  "description": "Postgres-backed sliding-window rate limiter. Sliding-window per-key buckets. No Redis required.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "llms.txt"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@021.is/spine-errors": "^0.4.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/021is/spine-ts.git",
    "directory": "packages/ratelimit"
  },
  "publishConfig": {
    "access": "public"
  }
}
