{
  "name": "@021is/spine-jobs",
  "version": "0.4.0",
  "description": "NATS JetStream publisher + consumer wrapper. Async fan-out + cron triggers + work queues, all going through the same NATS instance in the helvix cluster.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@021is/spine-errors": "^0.4.0",
    "nats": "^2.28.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/021is/spine-ts.git",
    "directory": "packages/jobs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
