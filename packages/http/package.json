{
  "name": "@021is/spine-http",
  "version": "0.3.0",
  "description": "Typed HTTP client base with resilience defaults (timeout, retry, circuit-break). TS twin of dc-rest-kotlin / 021-platform-rest.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@021is/spine-errors": "^0.3.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/021is/spine-ts.git",
    "directory": "packages/http"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
