{
  "name": "@021is/spine-telemetry",
  "version": "0.3.0",
  "description": "Pino structured JSON logger with Loki-friendly base fields (cluster, service, env) + AsyncLocalStorage request context so every log line auto-tags with request_id. OpenTelemetry tracer planned for next release.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pino": "^9.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/021is/spine-ts.git",
    "directory": "packages/telemetry"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
