{
  "name": "@021/spine-errors",
  "version": "0.1.0",
  "description": "ResponseDto envelope + typed exception hierarchy + framework-agnostic handler. Lifted from DanceClub's shared-lib.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/next.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=15 <17"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true }
  }
}
